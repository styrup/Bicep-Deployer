# Required — Azure AD App Registration
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-app-registration-client-id-here

# Required — Azure Blob Storage (one of the two options below)
# Option A: Connection string (easiest for local dev)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Option B: Managed Identity / az login (set account name, leave connection string empty)
# STORAGE_ACCOUNT_NAME=mystorageaccount

# Name of the Blob container holding your .bicep files
STORAGE_CONTAINER_NAME=bicep

# HTTP port (optional, defaults to 8080)
PORT=8080

# App branding (optional)
# APP_TITLE=Bicep Deployer
# APP_ICON=🚀
# APP_ICON=https://example.com/logo.png
